# aquestalk-server 環境変数の例。
# 実運用では .env にコピーして実値を入れる（.env はコミットしない）。

# aquestalk_cli バイナリのパス（必須）
AQUESTALK_CLI_PATH=/path/to/aquestalk_cli

# libAquesTalk10.dylib のあるディレクトリ（DYLD_LIBRARY_PATH に設定される）（必須）
AQUESTALK_SDK_DIR=/path/to/aquestalk10/sdk/lib

# AquesTalk10 ライセンスキー（subprocess の env に渡される。値は各自のライセンスに合わせる）
AQUESTALK_DEV_KEY=
AQUESTALK_USR_KEY=

# HTTP サーバーの bind アドレス・ポート
BIND_ADDR=127.0.0.1
PORT=8890
